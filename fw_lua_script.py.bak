#!/usr/bin/env python3
"""
FW LUA Script — Forsaken World Lua 5.1 Bytecode Tool
Backends: unluac.jar (decrypt) + luac (encrypt)
"""

import sys, os, subprocess, tempfile, shutil, argparse
from pathlib import Path

# Suppress the CMD window flash on Windows when spawning subprocesses
_NO_WINDOW = subprocess.CREATE_NO_WINDOW if sys.platform == 'win32' else 0


# ─────────────────────────────────────────────────────────────────────────────
# CONSTANTS
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME    = "FW LUA Script"
APP_VERSION = "2.0"
APP_YEAR    = "2025"

UNLUAC_JAR  = "unluac.jar"
LUAC_NAMES  = ["luac.exe", "luac5.1.exe", "luac", "luac5.1"]   # checked in order


# ─────────────────────────────────────────────────────────────────────────────
# TOOL RESOLUTION
# Search order:
#   1. _MEIPASS  — PyInstaller --onefile bundle (extracted temp dir)
#   2. Folder of the .exe  — PyInstaller --onedir, or files placed next to exe
#   3. Folder of this .py  — dev mode
#   4. Current working directory
#   5. System PATH  (luac only)
# ─────────────────────────────────────────────────────────────────────────────

def _search_dirs() -> list:
    """Return all candidate directories to search for bundled tools."""
    dirs = []
    # 1. PyInstaller --onefile: extracted bundle in temp folder
    meipass = getattr(sys, '_MEIPASS', None)
    if meipass:
        dirs.append(Path(meipass))
    # 2. Next to the .exe (--onedir, or user placed files manually)
    if getattr(sys, 'frozen', False):
        dirs.append(Path(sys.executable).parent)
    # 3. Next to this .py (dev mode)
    dirs.append(Path(__file__).parent)
    # 4. Current working directory
    dirs.append(Path(os.getcwd()))
    return dirs


def find_unluac() -> str | None:
    for folder in _search_dirs():
        p = folder / UNLUAC_JAR
        if p.is_file(): return str(p)
    return None


def find_luac() -> str | None:
    for name in LUAC_NAMES:
        for folder in _search_dirs():
            p = folder / name
            if p.is_file(): return str(p)
        found = shutil.which(name)
        if found: return found
    return None


def find_java() -> str | None:
    return shutil.which("java")


def tools_status() -> dict:
    return {
        "java":   find_java(),
        "unluac": find_unluac(),
        "luac":   find_luac(),
    }


# ─────────────────────────────────────────────────────────────────────────────
# AUTO OUTPUT PATH HELPERS
# ─────────────────────────────────────────────────────────────────────────────

def auto_decrypt_output(input_path: str) -> str:
    p = Path(input_path)
    return str(p.parent / f"{p.stem}_decrypted.lua")


def auto_encrypt_output(input_path: str) -> str:
    p    = Path(input_path)
    stem = p.stem
    if stem.endswith('_decrypted'):
        stem = stem[:-len('_decrypted')]
    return str(p.parent / f"{stem}_encrypted.lua")


# ─────────────────────────────────────────────────────────────────────────────
# CORE OPERATIONS
# ─────────────────────────────────────────────────────────────────────────────

def decrypt(input_path: str, output_path: str) -> str:
    """
    Decompile Lua 5.1 bytecode → readable source using unluac.jar.
    Returns the decompiled source as a string AND writes it to output_path.
    Raises RuntimeError with a descriptive message on failure.
    """
    st = tools_status()

    if not st["java"]:
        raise RuntimeError(
            "Java não encontrado.\n"
            "Instale o Java (JRE 8+) e certifique-se de que está no PATH do sistema.\n"
            "Download: https://adoptium.net"
        )
    if not st["unluac"]:
        raise RuntimeError(
            f"'{UNLUAC_JAR}' não encontrado.\n"
            f"Coloque o arquivo na mesma pasta que este programa.\n"
            f"Download: https://github.com/HansWessels/unluac/releases"
        )

    cmd = [st["java"], "-jar", st["unluac"], input_path]

    try:
        result = subprocess.run(cmd, capture_output=True, timeout=30,
                                creationflags=_NO_WINDOW)
    except subprocess.TimeoutExpired:
        raise RuntimeError("unluac demorou mais de 30 segundos — arquivo pode estar corrompido.")
    except FileNotFoundError as e:
        raise RuntimeError(f"Erro ao executar java: {e}")

    if result.returncode != 0:
        err = result.stderr.decode('utf-8', errors='replace').strip()
        raise RuntimeError(
            f"unluac falhou (código {result.returncode}).\n\n"
            f"Detalhes:\n{err or '(sem mensagem de erro)'}\n\n"
            f"Possível causa: o arquivo não é bytecode Lua 5.1 válido."
        )

    source = result.stdout.decode('utf-8', errors='replace')
    Path(output_path).write_text(source, encoding='utf-8')
    return source


def encrypt(input_path: str, output_path: str) -> int:
    """
    Compile Lua source → bytecode using luac.
    Returns the size of the output file in bytes.
    Raises RuntimeError with a descriptive message on failure.
    """
    st = tools_status()

    if not st["luac"]:
        raise RuntimeError(
            "luac não encontrado.\n"
            f"Coloque um dos seguintes na pasta do programa: {', '.join(LUAC_NAMES)}\n\n"
            f"Download (Windows): https://luabinaries.sourceforge.net\n"
            f"Download (Linux):   sudo apt install lua5.1"
        )

    cmd = [st["luac"], "-o", output_path, input_path]

    try:
        result = subprocess.run(cmd, capture_output=True, timeout=30,
                                creationflags=_NO_WINDOW)
    except subprocess.TimeoutExpired:
        raise RuntimeError("luac demorou mais de 30 segundos.")
    except FileNotFoundError as e:
        raise RuntimeError(f"Erro ao executar luac: {e}")

    if result.returncode != 0:
        err = result.stderr.decode('utf-8', errors='replace').strip()
        raise RuntimeError(
            f"luac falhou (código {result.returncode}).\n\n"
            f"Erro de sintaxe no arquivo fonte:\n{err}"
        )

    return Path(output_path).stat().st_size


# ─────────────────────────────────────────────────────────────────────────────
# GUI
# ─────────────────────────────────────────────────────────────────────────────

def gui_main():
    try:
        import tkinter as tk
        from tkinter import filedialog, messagebox, scrolledtext
    except ImportError:
        print("tkinter not available. Use CLI instead.")
        return

    # ── icon ─────────────────────────────────────────────────────────────────
    def get_icon_path() -> str | None:
        for c in [Path(sys.executable).parent / 'icon.ico',
                  Path(__file__).parent / 'icon.ico',
                  Path(os.getcwd()) / 'icon.ico']:
            if c.exists(): return str(c)
        return None

    # ── window ────────────────────────────────────────────────────────────────
    root = tk.Tk()
    root.title(f"{APP_NAME}  v{APP_VERSION}")
    root.resizable(False, False)

    icon = get_icon_path()
    if icon:
        try: root.iconbitmap(icon)
        except Exception: pass

    try:
        w, h = 660, 530
        sw, sh = root.winfo_screenwidth(), root.winfo_screenheight()
        root.geometry(f'{w}x{h}+{(sw-w)//2}+{(sh-h)//2}')
    except Exception: pass

    # ── palette ───────────────────────────────────────────────────────────────
    BG   = '#1e1e2e'
    FG   = '#cdd6f4'
    ACC  = '#89b4fa'
    PURP = '#cba6f7'
    SUB  = '#45475a'
    DARK = '#181825'
    OK   = '#a6e3a1'
    ERR  = '#f38ba8'
    WARN = '#fab387'
    MUTE = '#6c7086'

    root.configure(bg=BG)

    # ── title bar ─────────────────────────────────────────────────────────────
    frm_title = tk.Frame(root, bg=DARK, pady=10)
    frm_title.pack(fill='x')

    if icon:
        try:
            from PIL import Image, ImageTk
            img  = Image.open(icon).resize((28, 28))
            _img = ImageTk.PhotoImage(img)
            lbl_ico = tk.Label(frm_title, image=_img, bg=DARK)
            lbl_ico.image = _img
            lbl_ico.pack(side='left', padx=(16, 6))
        except Exception: pass

    tk.Label(frm_title, text=APP_NAME, bg=DARK, fg=ACC,
             font=('Segoe UI', 15, 'bold')).pack(side='left', padx=(16, 4))
    tk.Label(frm_title, text=f'v{APP_VERSION}', bg=DARK, fg=MUTE,
             font=('Segoe UI', 10)).pack(side='left', pady=4)

    # ── tools status bar ──────────────────────────────────────────────────────
    frm_tools = tk.Frame(root, bg='#12121c', pady=6, padx=16)
    frm_tools.pack(fill='x')

    tk.Label(frm_tools, text='Ferramentas:', bg='#12121c', fg=MUTE,
             font=('Segoe UI', 8, 'bold')).pack(side='left', padx=(0, 10))

    tool_dots = {}

    for name, display in [('java', 'Java'), ('unluac', 'unluac.jar'), ('luac', 'luac')]:
        frm = tk.Frame(frm_tools, bg='#12121c')
        frm.pack(side='left', padx=8)
        dot = tk.Label(frm, text='●', bg='#12121c', fg=MUTE, font=('Segoe UI', 9))
        dot.pack(side='left')
        tk.Label(frm, text=display, bg='#12121c', fg=FG,
                 font=('Segoe UI', 8)).pack(side='left', padx=(2, 0))
        tool_dots[name] = dot

    def refresh_tools():
        st = tools_status()
        for name, dot in tool_dots.items():
            dot.configure(fg=OK if st.get(name) else ERR)
        root.after(4000, refresh_tools)

    # ── helper: entry row ─────────────────────────────────────────────────────
    def make_row(parent, label, var, browse_cmd):
        row = tk.Frame(parent, bg=BG)
        row.pack(fill='x', pady=3)
        tk.Label(row, text=label, bg=BG, fg=FG, width=10,
                 font=('Segoe UI', 9), anchor='w').pack(side='left')
        ent = tk.Entry(row, textvariable=var, bg='#313244', fg=FG,
                       insertbackground=FG, relief='flat',
                       font=('Consolas', 9), bd=0, highlightthickness=1,
                       highlightbackground=SUB, highlightcolor=ACC)
        ent.pack(side='left', fill='x', expand=True, padx=(0, 4), ipady=4)
        tk.Button(row, text='Browse', bg=SUB, fg=FG, relief='flat',
                  font=('Segoe UI', 8), cursor='hand2',
                  activebackground=ACC, activeforeground=DARK,
                  command=browse_cmd).pack(side='left', ipadx=6, ipady=3)
        return ent

    # ── preview window ────────────────────────────────────────────────────────
    def open_preview(source: str, filename: str):
        win = tk.Toplevel(root)
        win.title(f'Preview — {filename}')
        win.configure(bg='#181825')
        if icon:
            try: win.iconbitmap(icon)
            except Exception: pass
        try:
            pw, ph = 860, 660
            sw2, sh2 = win.winfo_screenwidth(), win.winfo_screenheight()
            win.geometry(f'{pw}x{ph}+{(sw2-pw)//2}+{(sh2-ph)//2}')
        except Exception: pass

        bar = tk.Frame(win, bg='#313244', pady=6, padx=10)
        bar.pack(fill='x')
        tk.Label(bar, text=f'  {filename}', bg='#313244', fg=FG,
                 font=('Segoe UI', 9, 'bold')).pack(side='left')
        tk.Label(bar, text=f'{source.count(chr(10)) + 1} linhas', bg='#313244', fg=MUTE,
                 font=('Segoe UI', 8)).pack(side='left', padx=12)
        tk.Button(bar, text='Fechar', bg=SUB, fg=FG, relief='flat',
                  font=('Segoe UI', 8), cursor='hand2',
                  command=win.destroy).pack(side='right', ipadx=8, ipady=2)

        txt = scrolledtext.ScrolledText(win, bg='#1e1e2e', fg=FG,
                                        font=('Consolas', 10), relief='flat',
                                        wrap='none', bd=0,
                                        insertbackground=FG,
                                        selectbackground='#45475a')
        txt.pack(fill='both', expand=True)

        txt.tag_config('kw',  foreground='#cba6f7')
        txt.tag_config('str', foreground='#a6e3a1')
        txt.tag_config('num', foreground='#fab387')
        txt.tag_config('com', foreground='#6c7086')

        keywords = {'function','end','return','local','if','then','else','elseif',
                    'for','while','do','repeat','until','break','not','and','or',
                    'true','false','nil','in'}

        def highlight(code: str):
            i = 0; n = len(code)
            while i < n:
                c = code[i]
                if code[i:i+2] == '--':
                    j = code.find('\n', i); j = j if j != -1 else n
                    txt.insert('end', code[i:j], 'com'); i = j; continue
                if c in ('"', "'"):
                    j = i + 1
                    while j < n:
                        if code[j] == '\\': j += 2; continue
                        if code[j] == c: break
                        j += 1
                    txt.insert('end', code[i:j+1], 'str'); i = j + 1; continue
                if c.isdigit():
                    j = i
                    while j < n and (code[j].isdigit() or code[j] in '.eExX'): j += 1
                    txt.insert('end', code[i:j], 'num'); i = j; continue
                if c.isalpha() or c == '_':
                    j = i
                    while j < n and (code[j].isalnum() or code[j] == '_'): j += 1
                    word = code[i:j]
                    txt.insert('end', word, 'kw' if word in keywords else ''); i = j; continue
                txt.insert('end', c); i += 1

        highlight(source)
        txt.configure(state='disabled')

    # ── DECRYPT section ───────────────────────────────────────────────────────
    frm_dec = tk.LabelFrame(root, text='  Decrypt  (bytecode → source)',
                             bg=BG, fg=ACC, font=('Segoe UI', 9, 'bold'),
                             padx=14, pady=10, bd=1, relief='groove')
    frm_dec.pack(fill='x', padx=16, pady=(12, 6))

    var_dec_in  = tk.StringVar()
    var_dec_out = tk.StringVar()

    def browse_dec_in():
        path = filedialog.askopenfilename(
            title='Selecionar arquivo bytecode',
            filetypes=[('Lua files', '*.lua *.luac'), ('All files', '*.*')])
        if path:
            var_dec_in.set(path)
            var_dec_out.set(auto_decrypt_output(path))

    def browse_dec_out():
        path = filedialog.asksaveasfilename(
            title='Salvar arquivo decriptado como',
            defaultextension='.lua', filetypes=[('Lua files', '*.lua')])
        if path: var_dec_out.set(path)

    make_row(frm_dec, 'Input:', var_dec_in,  browse_dec_in)
    make_row(frm_dec, 'Output:', var_dec_out, browse_dec_out)

    def do_preview():
        inp = var_dec_in.get().strip()
        if not inp:
            messagebox.showwarning('Aviso', 'Selecione um arquivo de entrada.', parent=root)
            return
        try:
            with tempfile.NamedTemporaryFile(suffix='.lua', delete=False) as tmp:
                tmp_path = tmp.name
            source = decrypt(inp, tmp_path)
            Path(tmp_path).unlink(missing_ok=True)
            open_preview(source, Path(inp).name)
        except Exception as e:
            messagebox.showerror('Erro no Preview', str(e), parent=root)

    tk.Button(frm_dec, text='Preview', bg=SUB, fg=FG,
              relief='flat', font=('Segoe UI', 8), cursor='hand2',
              activebackground=ACC, activeforeground=DARK,
              command=do_preview).pack(anchor='e', ipadx=8, ipady=3, pady=(4, 0))

    # ── ENCRYPT section ───────────────────────────────────────────────────────
    frm_enc = tk.LabelFrame(root, text='  Encrypt  (source → bytecode)',
                             bg=BG, fg=PURP, font=('Segoe UI', 9, 'bold'),
                             padx=14, pady=10, bd=1, relief='groove')
    frm_enc.pack(fill='x', padx=16, pady=(6, 6))

    var_enc_in  = tk.StringVar()
    var_enc_out = tk.StringVar()

    def browse_enc_in():
        path = filedialog.askopenfilename(
            title='Selecionar arquivo fonte',
            filetypes=[('Lua files', '*.lua'), ('All files', '*.*')])
        if path:
            var_enc_in.set(path)
            var_enc_out.set(auto_encrypt_output(path))

    def browse_enc_out():
        path = filedialog.asksaveasfilename(
            title='Salvar arquivo encriptado como',
            defaultextension='.lua', filetypes=[('Lua files', '*.lua')])
        if path: var_enc_out.set(path)

    make_row(frm_enc, 'Input:', var_enc_in,  browse_enc_in)
    make_row(frm_enc, 'Output:', var_enc_out, browse_enc_out)

    # ── action buttons ────────────────────────────────────────────────────────
    frm_btn = tk.Frame(root, bg=BG)
    frm_btn.pack(fill='x', padx=16, pady=8)

    def do_decrypt():
        inp = var_dec_in.get().strip()
        out = var_dec_out.get().strip()
        if not inp:
            messagebox.showwarning('Aviso', 'Selecione um arquivo de entrada.', parent=root); return
        if not out:
            out = auto_decrypt_output(inp); var_dec_out.set(out)
        try:
            decrypt(inp, out)
            log_write(f'✓  Decriptado → {Path(out).name}', 'ok')
        except Exception as e:
            log_write(f'✗  {e}', 'err')

    def do_encrypt():
        inp = var_enc_in.get().strip()
        out = var_enc_out.get().strip()
        if not inp:
            messagebox.showwarning('Aviso', 'Selecione um arquivo de entrada.', parent=root); return
        if not out:
            out = auto_encrypt_output(inp); var_enc_out.set(out)
        try:
            size = encrypt(inp, out)
            log_write(f'✓  Encriptado → {Path(out).name}  ({size} bytes)', 'ok')
        except Exception as e:
            log_write(f'✗  {e}', 'err')

    btn_cfg = dict(relief='flat', cursor='hand2',
                   font=('Segoe UI', 10, 'bold'), pady=6, padx=20)

    tk.Button(frm_btn, text='🔓  Decrypt', bg=ACC, fg=DARK,
              activebackground='#74c7ec', activeforeground=DARK,
              command=do_decrypt, **btn_cfg).pack(side='left', padx=(0, 10))

    tk.Button(frm_btn, text='🔒  Encrypt', bg=PURP, fg=DARK,
              activebackground='#b4befe', activeforeground=DARK,
              command=do_encrypt, **btn_cfg).pack(side='left')

    tk.Button(frm_btn, text='Limpar log', bg=SUB, fg=FG,
              activebackground='#585b70', activeforeground=FG,
              relief='flat', cursor='hand2', font=('Segoe UI', 9),
              command=lambda: [log.configure(state='normal'),
                               log.delete('1.0', 'end'),
                               log.configure(state='disabled')]
              ).pack(side='right')

    # ── log ───────────────────────────────────────────────────────────────────
    log = scrolledtext.ScrolledText(root, height=6, bg=DARK, fg=FG,
                                    font=('Consolas', 9), relief='flat',
                                    state='disabled', bd=0)
    log.pack(fill='both', expand=True, padx=16, pady=(0, 4))
    log.tag_config('ok',   foreground=OK)
    log.tag_config('err',  foreground=ERR)
    log.tag_config('inf',  foreground=ACC)
    log.tag_config('warn', foreground=WARN)

    def log_write(msg, tag='inf'):
        log.configure(state='normal')
        log.insert('end', msg + '\n', tag)
        log.see('end')
        log.configure(state='disabled')

    # ── footer ────────────────────────────────────────────────────────────────
    tk.Label(root, text=f'{APP_NAME}  v{APP_VERSION}  •  {APP_YEAR}',
             bg=DARK, fg=MUTE, font=('Segoe UI', 8)).pack(
             fill='x', pady=4, side='bottom')

    # ── startup check ─────────────────────────────────────────────────────────
    def startup_check():
        refresh_tools()
        st = tools_status()
        missing = []
        if not st['java']:
            missing.append("  • Java (JRE 8+)    →  https://adoptium.net")
        if not st['unluac']:
            missing.append(f"  • {UNLUAC_JAR}  →  https://github.com/HansWessels/unluac/releases")
        if not st['luac']:
            missing.append("  • luac.exe          →  https://luabinaries.sourceforge.net  (Windows)")
            missing.append("                          sudo apt install lua5.1              (Linux)")
        if missing:
            log_write("⚠  Ferramentas em falta — coloque-as na mesma pasta do programa:", 'warn')
            for line in missing:
                log_write(line, 'warn')
        else:
            log_write("✓  Todas as ferramentas encontradas. Pronto para usar.", 'ok')

    root.after(150, startup_check)
    root.mainloop()


# ─────────────────────────────────────────────────────────────────────────────
# CLI
# ─────────────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) == 1:
        gui_main()
        return

    p = argparse.ArgumentParser(
        description=f'{APP_NAME} v{APP_VERSION} — Forsaken World Lua 5.1 Bytecode Tool\n'
                    f'Decrypt: unluac.jar   |   Encrypt: luac',
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    sub = p.add_subparsers(dest='cmd')

    d = sub.add_parser('decrypt', help='Bytecode → readable source  (usa unluac.jar)')
    d.add_argument('input')
    d.add_argument('-o', '--output', default=None)

    e = sub.add_parser('encrypt', help='Readable source → bytecode  (usa luac)')
    e.add_argument('input')
    e.add_argument('-o', '--output', default=None)

    sub.add_parser('status', help='Verifica se as ferramentas estão disponíveis')

    args = p.parse_args()

    if args.cmd == 'status':
        st = tools_status()
        for name, path in st.items():
            print(f"  {name:10s}  {'OK  → ' + path if path else 'NÃO ENCONTRADO'}")
        sys.exit(0 if all(st.values()) else 1)

    elif args.cmd == 'decrypt':
        out = args.output or auto_decrypt_output(args.input)
        try:
            decrypt(args.input, out)
            print(f'[OK] Decriptado → {out}')
        except RuntimeError as e:
            print(f'[ERRO] {e}', file=sys.stderr); sys.exit(1)

    elif args.cmd == 'encrypt':
        out = args.output or auto_encrypt_output(args.input)
        try:
            size = encrypt(args.input, out)
            print(f'[OK] Encriptado → {out}  ({size} bytes)')
        except RuntimeError as e:
            print(f'[ERRO] {e}', file=sys.stderr); sys.exit(1)

    else:
        p.print_help()


if __name__ == '__main__':
    main()
